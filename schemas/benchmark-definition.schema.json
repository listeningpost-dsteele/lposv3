{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lpos.local/schemas/benchmark-definition.schema.json",
  "title": "LPOS v4 Benchmark Definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "component_type",
    "component_id",
    "objective",
    "fixture_version",
    "scenario",
    "inputs",
    "expected",
    "success_criteria",
    "failure_criteria",
    "evaluation",
    "evidence"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^BENCH-[SO][0-9]{3}$"},
    "component_type": {"enum": ["specialist", "standing_operation"]},
    "component_id": {"type": "string", "pattern": "^(SPECIALIST|SO)-[0-9]{3}$"},
    "objective": {"type": "string", "minLength": 1},
    "fixture_version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "scenario": {"type": "string", "minLength": 1},
    "inputs": {"type": "object", "minProperties": 1},
    "expected": {"type": "object", "minProperties": 1},
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "failure_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "assertions"],
      "properties": {
        "method": {"type": "string", "minLength": 1},
        "assertions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
