{
  "$id": "https://lpos.local/schemas/action-plan.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "action_hash": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "action_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^\\S+$",
      "type": "string"
    },
    "approval_required": {
      "type": "boolean"
    },
    "created_at": {
      "format": "date-time",
      "type": "string"
    },
    "exact_action": {
      "minLength": 1,
      "type": "string"
    },
    "external": {
      "type": "boolean"
    },
    "idempotency_key": {
      "minLength": 1,
      "type": "string"
    },
    "kind": {
      "minLength": 1,
      "type": "string"
    },
    "parameters": {
      "type": "object"
    },
    "reversible": {
      "type": "boolean"
    },
    "risk_tags": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "task_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^\\S+$",
      "type": "string"
    }
  },
  "required": [
    "action_id",
    "task_id",
    "kind",
    "parameters",
    "external",
    "reversible",
    "approval_required",
    "exact_action",
    "action_hash",
    "idempotency_key",
    "risk_tags",
    "created_at"
  ],
  "title": "ActionPlan",
  "type": "object"
}
