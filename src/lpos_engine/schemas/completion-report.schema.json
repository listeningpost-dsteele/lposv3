{
  "$id": "https://lpos.local/schemas/completion-report.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "actions": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "artifact_hash": {
      "pattern": "^[a-f0-9]{64}$",
      "type": [
        "string",
        "null"
      ]
    },
    "artifact_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "completed_at": {
      "format": "date-time",
      "type": "string"
    },
    "decision_ids": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "evidence_ids": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "limitations": {
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "material": {
      "type": "boolean"
    },
    "result_summary": {
      "minLength": 1,
      "type": "string"
    },
    "review_decision": {
      "enum": [
        "PASS",
        "REJECT",
        null
      ]
    },
    "review_isolated": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "status": {
      "const": "completed"
    },
    "task_id": {
      "maxLength": 128,
      "minLength": 1,
      "pattern": "^\\S+$",
      "type": "string"
    }
  },
  "required": [
    "task_id",
    "status",
    "result_summary",
    "artifact_id",
    "artifact_hash",
    "material",
    "review_decision",
    "review_isolated",
    "actions",
    "evidence_ids",
    "decision_ids",
    "limitations",
    "completed_at"
  ],
  "title": "CompletionReport",
  "type": "object"
}
