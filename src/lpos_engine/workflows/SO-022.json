      ],
      "continue_on_error": true
    },
    {
      "step_id": "STEP-RESOLVE",
      "handler": "resolve_or_escalate",
      "depends_on": [
        "STEP-REVIEW"
      ],
      "continue_on_error": false
    },
    {
      "step_id": "STEP-NOTIFY",
      "handler": "notify_reporter_outcome",
